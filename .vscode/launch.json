// VS Code debug configurations for the 51Degrees Rust workspace.
// Debugging uses the CodeLLDB extension (vadimcn.vscode-lldb), which works on
// Linux, macOS and Windows and resolves the built binary path (including the
// Windows .exe suffix) through its cargo integration, so these configs are
// cross-platform. Windows-MSVC users who prefer the Microsoft debugger can
// change "type" to "cppvsdbg" and point "program" at target/debug/<name>.exe.
{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "exampleBin",
      "type": "pickString",
      "description": "Example binary to debug",
      "options": [
        "dd-cloud-configurator",
        "dd-cloud-get-all-properties",
        "dd-cloud-getting-started",
        "dd-cloud-metadata",
        "dd-cloud-native-model",
        "dd-cloud-tac",
        "dd-onprem-getting-started",
        "dd-onprem-match-metrics",
        "dd-onprem-metadata",
        "dd-onprem-offline-processing",
        "dd-onprem-performance",
        "dd-onprem-update-data-file",
        "dd-web-client-only-cloud",
        "dd-web-getting-started-cloud",
        "dd-web-getting-started-onprem",
        "dd-web-uach",
        "ipi-cloud-get-all-properties",
        "ipi-cloud-getting-started",
        "ipi-cloud-metadata",
        "ipi-cloud-mixed-getting-started",
        "ipi-onprem-compare",
        "ipi-onprem-getting-started",
        "ipi-onprem-metadata",
        "ipi-onprem-metrics",
        "ipi-onprem-offline-processing",
        "ipi-onprem-performance",
        "ipi-onprem-suspicious",
        "ipi-onprem-update-data-file",
        "ipi-web-getting-started-cloud",
        "ipi-web-getting-started-onprem",
        "caching",
        "ss-clientside",
        "ss-cloud",
        "ss-onprem",
        "ss-simple",
        "usage-sharing"
      ]
    }
  ],
  "configurations": [
